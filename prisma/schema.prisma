generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Users ─────────────────────────────────────────────────────────────

enum UserRole {
  recruit
  coach_admin
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  role            UserRole
  displayName     String
  avatarUrl       String?
  schoolId        String?
  school          School?   @relation("SchoolAdmin", fields: [schoolId], references: [id])
  recruitType     String?   // "high_school" | "transfer"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  recruitProfile          RecruitProfile?
  notificationPreference  NotificationPreference?
  favorites               Favorite[]
  jerseySelections        JerseySelection[]
  analyticsEvents         AnalyticsEvent[]
  createdInvites          InviteLink[]
  coachNotes              RecruitNote[]      @relation("CoachNotes")
  recruitNotes            RecruitNote[]      @relation("RecruitNotes")
  recruitTags             RecruitTag[]
  recruitListMembers      RecruitListMember[]
  recruitStatuses         RecruitStatus[]
  createdLists            RecruitList[]

  @@map("users")
}

model RecruitProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sport               String?
  position            String?
  height              String?
  weight              Int?
  graduationYear      Int?
  gpa                 Float?
  satScore            Int?
  actScore            Int?
  highSchool          String?
  city                String?
  state               String?
  bio                 String?  @db.Text
  highlightsUrl       String?
  currentSchool       String?
  collegeStats        String?  @db.Text
  eligibilityYears    Int?
  transferReason      String?  @db.Text
  profilePhotoUrl     String?
  profileCompleteness Float?   @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([sport, graduationYear, state])
  @@index([position])
  @@map("recruit_profiles")
}

// ─── Schools ──────────────────────────────────────────────────────────────────

model School {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  shortName          String
  mascot             String
  conference         String
  city               String
  state              String
  scorecardId        String?
  colorPrimary       String
  colorSecondary     String
  colorAccent        String
  logoUrl            String?
  heroImageUrl       String?
  description        String   @db.Text
  stadiumCapacity    Int?
  traditions         String?  @db.Text
  gameDayDescription String?  @db.Text
  welcomeVideoUrl    String?
  defaultWelcomeMsg  String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  admins             User[]              @relation("SchoolAdmin")
  academics          SchoolAcademics?
  colleges           College[]
  sports             Sport[]
  facilities         Facility[]
  jerseyAssets       JerseyAsset[]
  favorites          Favorite[]
  analyticsEvents    AnalyticsEvent[]
  inviteLinks        InviteLink[]
  jerseySelections   JerseySelection[]
  nilProgram         NilProgram?
  notableAlumni      NotableAlumni[]
  rosterPlayers      RosterPlayer[]
  videos             SchoolVideo[]
  recruitNotes       RecruitNote[]
  recruitTags        RecruitTag[]
  recruitLists       RecruitList[]
  recruitStatuses    RecruitStatus[]
  nilFieldVisibility NilFieldVisibility?

  @@map("schools")
}

model SchoolAcademics {
  id                     String @id @default(uuid())
  schoolId               String @unique
  school                 School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  enrollment             Int
  admissionRate          Float
  satAvg                 Int
  actAvg                 Int
  tuitionInState         Int
  tuitionOutOfState      Int
  graduationRate         Float
  medianEarnings         Int
  retentionRate          Float
  studentToFacultyRatio  Float?
  averageClassSize       Int?
  ranking                Int?
  athleteGraduationRate  Float?

  @@map("school_academics")
}

// ─── Academics ────────────────────────────────────────────────────────────────

model College {
  id            String  @id @default(uuid())
  schoolId      String
  school        School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  slug          String
  name          String
  description   String  @db.Text
  totalStudents Int
  imageUrl      String?

  majors Major[]

  @@unique([schoolId, slug])
  @@index([schoolId])
  @@map("colleges")
}

model Major {
  id          String  @id @default(uuid())
  collegeId   String
  college     College @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  name        String
  degreeType  String
  description String  @db.Text

  pathways       DegreePathway[]
  careerOutcomes CareerOutcome[]

  @@index([collegeId])
  @@map("majors")
}

model DegreePathway {
  id          String   @id @default(uuid())
  majorId     String
  major       Major    @relation(fields: [majorId], references: [id], onDelete: Cascade)
  year        Int
  title       String
  courses     String[]
  description String   @db.Text

  @@index([majorId])
  @@map("degree_pathways")
}

model CareerOutcome {
  id           String @id @default(uuid())
  majorId      String
  major        Major  @relation(fields: [majorId], references: [id], onDelete: Cascade)
  title        String
  medianSalary Int
  growthRate   Float
  description  String @db.Text

  @@index([majorId])
  @@map("career_outcomes")
}

// ─── Athletics ────────────────────────────────────────────────────────────────

model Sport {
  id                 String   @id @default(uuid())
  schoolId           String
  school             School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name               String
  conference         String
  headCoach          String
  record             String?
  ranking            Int?
  offensiveScheme    String?
  defensiveScheme    String?
  offenseDescription String?  @db.Text
  defenseDescription String?  @db.Text
  strengthProgram    String?  @db.Text
  nutritionProgram   String?  @db.Text
  recentBowlGames   String[]
  conferenceStanding String?

  coaches    Coach[]
  facilities Facility[]

  @@index([schoolId])
  @@map("sports")
}

model Coach {
  id            String   @id @default(uuid())
  sportId       String
  sport         Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)
  name          String
  title         String
  imageUrl      String?
  bio           String   @db.Text
  yearsAtSchool Int
  careerRecord  String?
  championships String[]
  previousRoles String[]
  awards        String[]
  playersInNfl  Int?
  videoUrl      String?
  coachingTree  String[]

  videos SchoolVideo[]

  @@index([sportId])
  @@map("coaches")
}

model RosterPlayer {
  id         String  @id @default(uuid())
  schoolId   String
  school     School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name       String
  number     Int
  position   String
  height     String
  weight     Int
  year       String
  hometown   String
  state      String
  highSchool String?
  imageUrl   String?
  isStarter  Boolean @default(false)

  @@index([schoolId])
  @@map("roster_players")
}

// ─── NIL & Alumni ───────────────────────────────────────────────────────────

model NilProgram {
  id              String  @id @default(uuid())
  schoolId        String  @unique
  school          School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  collectiveName  String
  totalBudget     Int
  footballSpend   Int
  allSportsSpend  Int
  founded         Int
  description     String  @db.Text
  notableDeals    Json?
  averageDealSize Int?
  howToGetInvolved String? @db.Text

  @@map("nil_programs")
}

model NotableAlumni {
  id               String  @id @default(uuid())
  schoolId         String
  school           School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name             String
  position         String
  draftYear        Int
  draftRound       Int
  draftPick        Int
  nflTeam          String
  careerHighlights String  @db.Text
  isFirstRound     Boolean @default(false)
  isActive         Boolean @default(true)

  @@index([schoolId])
  @@map("notable_alumni")
}

// ─── Facilities & Tours ───────────────────────────────────────────────────────

model Facility {
  id           String   @id @default(uuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sportId      String?
  sport        Sport?   @relation(fields: [sportId], references: [id], onDelete: SetNull)
  name         String
  type         String
  description  String   @db.Text
  imageUrl     String?
  panoramaUrl  String?
  panoramaType String?          // "photo" | "video"
  videoUrl     String?
  sortOrder    Int      @default(0)
  isRequired   Boolean  @default(false)

  hotspots       Hotspot[]
  linkedHotspots Hotspot[] @relation("HotspotLinks")

  @@index([schoolId])
  @@index([sportId])
  @@map("facilities")
}

model Hotspot {
  id               String    @id @default(uuid())
  facilityId       String
  facility         Facility  @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  x                Float
  y                Float
  z                Float     @default(0)
  label            String
  description      String    @db.Text
  linkedFacilityId String?
  linkedFacility   Facility? @relation("HotspotLinks", fields: [linkedFacilityId], references: [id], onDelete: SetNull)

  @@index([facilityId])
  @@map("hotspots")
}

// ─── Jersey Customization ─────────────────────────────────────────────────────

model JerseyAsset {
  id         String @id @default(uuid())
  schoolId   String
  school     School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  type       String
  colorLabel String
  imageUrl   String

  @@index([schoolId])
  @@map("jersey_assets")
}

model JerseySelection {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  helmetId  String
  jerseyId  String
  pantsId   String
  createdAt DateTime @default(now())

  @@index([schoolId])
  @@index([userId])
  @@map("jersey_selections")
}

// ─── Analytics ────────────────────────────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  sessionId String
  section   String
  action    String
  metadata  Json?
  duration  Int?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([schoolId])
  @@index([createdAt])
  @@index([userId, schoolId])
  @@index([schoolId, userId, section])
  @@index([schoolId, createdAt])
  @@map("analytics_events")
}

// ─── SaaS Features ────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, schoolId])
  @@map("favorites")
}

model InviteLink {
  id              String    @id @default(uuid())
  schoolId        String
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdBy       String
  creator         User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  code            String    @unique
  expiresAt       DateTime?
  usedCount       Int       @default(0)
  welcomeMessage  String?   @db.Text
  welcomeVideoUrl String?
  createdAt       DateTime  @default(now())

  @@map("invite_links")
}

model NotificationPreference {
  id                 String  @id @default(uuid())
  userId             String  @unique
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  coachViewedProfile Boolean @default(true)
  newSchoolAdded     Boolean @default(true)
  weeklyDigest       Boolean @default(false)
  marketingEmails    Boolean @default(false)

  @@map("notification_preferences")
}

// ─── Video Content ────────────────────────────────────────────────────────────

model SchoolVideo {
  id           String   @id @default(uuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  type         String   // "coach_intro" | "highlight" | "day_in_life"
  title        String
  description  String?  @db.Text
  videoUrl     String
  thumbnailUrl String?
  coachId      String?
  coach        Coach?   @relation(fields: [coachId], references: [id], onDelete: SetNull)
  playerName   String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([schoolId])
  @@map("school_videos")
}

// ─── Coach CRM ────────────────────────────────────────────────────────────────

model RecruitNote {
  id        String   @id @default(uuid())
  coachId   String
  coach     User     @relation("CoachNotes", fields: [coachId], references: [id], onDelete: Cascade)
  recruitId String
  recruit   User     @relation("RecruitNotes", fields: [recruitId], references: [id], onDelete: Cascade)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([recruitId])
  @@index([schoolId])
  @@index([coachId])
  @@map("recruit_notes")
}

model RecruitTag {
  id        String   @id @default(uuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  recruitId String
  recruit   User     @relation(fields: [recruitId], references: [id], onDelete: Cascade)
  tag       String
  createdAt DateTime @default(now())

  @@unique([schoolId, recruitId, tag])
  @@map("recruit_tags")
}

model RecruitList {
  id        String   @id @default(uuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  createdBy String
  creator   User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  members RecruitListMember[]

  @@index([schoolId])
  @@map("recruit_lists")
}

model RecruitListMember {
  id        String      @id @default(uuid())
  listId    String
  list      RecruitList @relation(fields: [listId], references: [id], onDelete: Cascade)
  recruitId String
  recruit   User        @relation(fields: [recruitId], references: [id], onDelete: Cascade)
  addedAt   DateTime    @default(now())

  @@unique([listId, recruitId])
  @@index([listId])
  @@index([recruitId])
  @@map("recruit_list_members")
}

model RecruitStatus {
  id        String   @id @default(uuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  recruitId String
  recruit   User     @relation(fields: [recruitId], references: [id], onDelete: Cascade)
  status    String   // "invited" | "viewed" | "engaged" | "contacted" | "visited" | "offered" | "committed"
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([schoolId, recruitId])
  @@map("recruit_statuses")
}

// ─── NIL Visibility ───────────────────────────────────────────────────────────

model NilFieldVisibility {
  id              String @id @default(uuid())
  schoolId        String @unique
  school          School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  totalBudget     String @default("public")       // "public" | "invite_only" | "hidden"
  footballSpend   String @default("public")
  allSportsSpend  String @default("hidden")
  averageDealSize String @default("invite_only")
  notableDeals    String @default("invite_only")

  @@map("nil_field_visibility")
}
